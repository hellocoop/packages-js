{
  "extends": "@tsconfig/node18/tsconfig.json",
  "include": ["src", "../helper/src"],
  "exclude": ["node_modules", "./**/dist"],
  "compilerOptions": {
      "lib": ["dom"],
      "declarationMap": true,
      "declaration": true,
      "baseUrl": ".",
      "target": "es2019",
      "strict": true,
      "forceConsistentCasingInFileNames": true,
      "outDir": "./dist",
      "paths": {
        "@helper/*": ["../helper/src/*"]
      }
  }
}